  "dangerous_commands": {
    "block": [
      {"id": "vercel_cli", "pattern": "\\bvercel\\b", "message": "Vercel CLIは認証・deploy・環境変数・project linkに触れる可能性があるため、このプロジェクトでは明示指示なしに実行しません。"},
      {"id": "netlify_deploy", "pattern": "\\bnetlify\\s+deploy\\b", "message": "Netlify deployは公開サイト更新に直結するためブロックします。"},
      {"id": "firebase_deploy", "pattern": "\\bfirebase\\s+deploy\\b", "message": "Firebase Hosting deployは公開サイト更新に直結するためブロックします。"},
      {"id": "production_ssh_root", "pattern": "\\bssh\\s+[^\\n]*root@", "message": "production SSHは禁止です。必要なら手動手順だけを提示してください。"},
      {"id": "prod_opt_path", "pattern": "/opt/anpi-watch", "message": "production配下の変更は禁止です。"},
      {"id": "prod_docker_compose", "pattern": "docker-compose\\s+-f\\s+docker-compose\\.prod\\.yml", "message": "production Docker操作は禁止です。"},
      {"id": "run_escalation", "pattern": "\\brun_escalation\\b", "message": "run_escalationは通知送信や本番データ変更につながるためブロックします。"},
      {"id": "twilio_send", "pattern": "\\b(twilio|send_sms|send-sms)\\b.*\\b(send|messages|api)\\b", "message": "SMS実送信につながるコマンドはブロックします。"},
      {"id": "stripe_or_billing", "pattern": "\\b(stripe|storekit|refund|課金開始|返金)\\b", "message": "課金開始、返金、決済操作に見えるコマンドはブロックします。"},
      {"id": "bulk_email", "pattern": "\\b(mailchimp|sendgrid|aws\\s+ses|sesv2|bulk email|一斉送信)\\b", "message": "メール一斉送信や外部通知はブロックします。"},
      {"id": "destructive_git", "pattern": "\\bgit\\s+(reset\\s+--hard|clean\\s+-fd|checkout\\s+--)\\b", "message": "作業ツリー破壊につながるgit操作はブロックします。"},
      {"id": "dangerous_rm", "pattern": "\\brm\\s+-rf\\s+(/|\\$HOME|~|\\.\\.)", "message": "広範囲削除はブロックします。"},
      {"id": "env_dump", "pattern": "\\b(printenv|env)\\b\\s*(\\||>|$)|\\b(cat|sed|less|more)\\b\\s+\\.env", "message": ".envや環境変数の読み出しは秘密情報漏えいにつながるためブロックします。"}
    ],
    "warn": [
      {"id": "curl_post_external", "pattern": "\\bcurl\\b[^\\n]*(--request\\s+POST|-X\\s*POST)\\b", "message": "外部POST送信は、フォーム送信・通知・課金・公開更新につながらないか確認が必要です。"},
      {"id": "npm_run_deploy", "pattern": "\\bnpm\\s+run\\s+deploy\\b", "message": "deploy scriptは公開更新の可能性があるため確認が必要です。"},
      {"id": "git_push_main_prod", "pattern": "\\bgit\\s+push\\b[^\\n]*(main|production|prod)", "message": "main/prodへのpushは公開・CI連動の可能性があるため確認が必要です。"}
    ]
  },
  "secret_patterns": [
    {"id": "openai_key", "pattern": "\\bsk-(?:proj-)?[A-Za-z0-9_-]{20,}\\b", "message": "OpenAI APIキーらしき値を検出しました。"},
    {"id": "github_token", "pattern": "\\b(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{20,}\\b|\\bgithub_pat_[A-Za-z0-9_]{20,}\\b", "message": "GitHub tokenらしき値を検出しました。"},
    {"id": "aws_key", "pattern": "\\b(?:AKIA|ASIA)[A-Z0-9]{16}\\b", "message": "AWS access keyらしき値を検出しました。"},
    {"id": "stripe_secret", "pattern": "\\b(?:sk|rk)_(?:live|test)_[A-Za-z0-9]{16,}\\b", "message": "Stripe secret keyらしき値を検出しました。"},
    {"id": "twilio_token_assignment", "pattern": "(?i)\\bTWILIO_[A-Z0-9_]*(?:TOKEN|SECRET|KEY)\\b\\s*[:=]\\s*['\\\"]?[^\\s'\\\"]{12,}", "message": "Twilio秘密値らしき代入を検出しました。"},
    {"id": "firebase_google_api", "pattern": "\\bAIza[0-9A-Za-z_-]{25,}\\b", "message": "Google/Firebase APIキーらしき値を検出しました。"},
    {"id": "private_key", "pattern": "-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----", "message": "秘密鍵らしき値を検出しました。"},
    {"id": "generic_secret_assignment", "pattern": "(?i)\\b(?:API_KEY|SECRET|TOKEN|PASSWORD|PRIVATE_KEY|AUTH_TOKEN)\\b\\s*[:=]\\s*['\\\"]?[A-Za-z0-9_./+=-]{16,}", "message": "秘密情報らしき代入を検出しました。"}
  ],
  "copy_patterns": {
    "allowed_price_yen": 300,
