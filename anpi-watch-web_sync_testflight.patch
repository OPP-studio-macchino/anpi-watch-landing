+import Link from "next/link";
+import { manualSections, type Tone } from "./helpData";
+import styles from "./HelpPage.module.css";
+
+function toneClass(tone: Tone | undefined) {
+  if (tone === "success") return styles.toneSuccess;
+  if (tone === "info") return styles.toneInfo;
+  if (tone === "warning") return styles.toneWarning;
+  if (tone === "critical") return styles.toneCritical;
+  return "";
+}
+
+export function ManualPage() {
+  return (
+    <main className={styles.page}>
+      <div className={styles.shell}>
+        <div className={styles.heroGrid}>
+          <header className={styles.hero}>
+            <p className={styles.eyebrow}>使い方マニュアル</p>
+            <h1>毎日OKを押す。反応がない時は順番に知らせる。</h1>
+            <p className={styles.lead}>
+              あんぴッチは、最後のOK時刻をもとに通知します。危険や死亡を判断するアプリではありません。
+            </p>
+            <p className={styles.lead}>迷った時は、まずホームでOKを押せたかを見ます。</p>
+          </header>
+
+          <aside className={styles.statusCard} aria-label="最初に覚えること">
+            <p className={styles.eyebrow}>これだけ覚える</p>
+            <strong>ホームでOKを1日1回</strong>
+            <p className={styles.body}>アプリを開くだけでは記録されません。OKを押した時だけ記録されます。</p>
+          </aside>
+        </div>
+
+        <nav className={styles.navCard} aria-label="マニュアルの目次">
+          <div className={styles.navList}>
+            {manualSections.map((section) => (
+              <a key={section.id} className={styles.navLink} href={`#${section.id}`}>
+                {section.title}
+              </a>
+            ))}
+            <Link className={styles.navLink} href="/manual/tutorial">3分体験コース</Link>
+            <Link className={styles.navLink} href="/manual/faq">FAQ</Link>
+          </div>
+        </nav>
+
+        <div className={styles.content}>
+          {manualSections.map((section) => (
+            <section key={section.id} id={section.id} className={`${styles.card} ${toneClass(section.tone)}`}>
+              <header className={styles.cardHeader}>
+                <p className={styles.eyebrow}>{section.eyebrow}</p>
+                <h2>{section.title}</h2>
+              </header>
+              <p className={styles.answer}>
+                <strong>答え: </strong>
+                {section.answer}
+              </p>
+              <ul className={styles.list}>
+                {section.points.map((point) => (
+                  <li key={point}>{point}</li>
+                ))}
+              </ul>
+              <p className={styles.nextAction}>
+                <strong>次にやること: </strong>
+                {section.nextAction}
+              </p>
+            </section>
+          ))}
+        </div>
+      </div>
+    </main>
+  );
+}
